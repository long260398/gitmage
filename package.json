{
  "name": "gitmage",
  "version": "0.2.0",
  "description": "Generate conventional commit messages from staged changes using AI",
  "main": "dist/index.js",
  "bin": {
    "gitmage": "bin/ai-commit"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "claude",
    "groq",
    "llama",
    "conventional-commits",
    "cli",
    "developer-tools",
    "anthropic",
    "multilingual",
    "automation"
  ],
  "author": "long260398",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.28.0",
    "chalk": "^4.1.2",
    "groq-sdk": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
